# pyenv
#   For a library or app, you might want to share your .python-version if you're
#   using pyenv and micro-managing python versions.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a pyenv version or another local paths,
#   pipenv recommends to ignore Pipfile.lock.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry recommends to include poetry.lock in version control.
# Poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm recommends to include pdm.lock in version control.
# pdm.lock
#   pdm local configuration
.pdm-python
#   pdm local variables
.pdm.toml

# PEP 582; project local packages directory (used by pdm)
